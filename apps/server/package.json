{
  "name": "@your_spotify/server",
  "version": "1.18.0",
  "private": true,
  "scripts": {
    "build": "rsbuild build",
    "buildold": "tsc && cp -r src/public build/",
    "start": "node build/index.js",
    "typecheck": "tsc --noEmit",
    "dev": "concurrently \"rsbuild dev\" \"nodemon build/index.js\"",
    "migrate": "node ./build/index.js --migrate",
    "lint": "oxlint -c ./node_modules/@your_spotify/dev/.oxlintrc.json && oxfmt -c ./node_modules/@your_spotify/dev/.oxfmtrc.json",
    "lint:fix": "oxlint --fix -c ./node_modules/@your_spotify/dev/.oxlintrc.json && oxfmt --write -c ./node_modules/@your_spotify/dev/.oxfmtrc.json"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "express-basic-auth": "^1.2.1",
    "fuse.js": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "migrate": "^2.1.0",
    "mongodb": "^7.0.0",
    "mongoose": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "prom-client": "^15.1.3",
    "uuid": "^13.0.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@rsbuild/core": "catalog:",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.3",
    "@your_spotify/dev": "workspace:*",
    "concurrently": "^9.2.1",
    "globals": "catalog:",
    "ts-node": "^10.9.2",
    "typescript": "catalog:"
  }
}
